generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model badges {
  id           Int           @id @default(autoincrement())
  name         String
  number       String?
  description  String?
  image_src    String?
  competences  competences[]
  realisations realisations[]
}

model competences {
  id          Int     @id @default(autoincrement())
  badge_id    Int
  description String
  badge       badges  @relation(fields: [badge_id], references: [id])
}

model realisations {
  id          Int     @id @default(autoincrement())
  badge_id    Int
  description String
  badge       badges  @relation(fields: [badge_id], references: [id])
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  name     String
  role     Role
  
  @@map("users")
}

enum Role {
  ADMIN
  CHEF
  REFERENT
}